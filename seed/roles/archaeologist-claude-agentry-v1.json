{
  "name": "archaeologist-claude-agentry",
  "version": 1,
  "model": "claude-max",
  "system_prompt": null,
  "image": "docker.io/library/rust:1.93",
  "substrate_class": "podman",
  "package_manager": "apt",
  "entrypoint_script": "#!/bin/sh\nexec /usr/local/bin/archaeologist-runner\n",
  "binaries": [],
  "mcp_servers": [],
  "tool_allowlist": [],
  "permit_scope": [
    "fs:read:/workspace/**",
    "fs:write:/workspace/**",
    "net:allow:api.anthropic.com",
    "${FORGE_NET_ALLOW}",
    "${SCCACHE_NET_ALLOW}"
  ],
  "passthru_env": ["GITEA_TOKEN"],
  "mounts": [
    {
      "source": "${HOME}/.local/bin/claude",
      "target": "/usr/local/bin/claude",
      "readonly": true
    },
    {
      "source": "${HOME}/.claude/.credentials.json",
      "target": "/root/.claude/.credentials.json",
      "readonly": true
    },
    {
      "source": "${HOME}/.config/agentry/claude-container-settings.json",
      "target": "/root/.claude/settings.json",
      "readonly": true
    },
    {
      "source": "/var/lib/agentry/transcripts",
      "target": "/transcripts",
      "readonly": false
    },
    {
      "source": "${HOME}/.local/bin/archaeologist-runner",
      "target": "/usr/local/bin/archaeologist-runner",
      "readonly": true
    },
    {
      "source": "${HOME}/.local/bin/rtk",
      "target": "/usr/local/bin/rtk",
      "readonly": true
    }
  ],
  "workspace_mount": {
    "container_path": "/workspace",
    "readonly": false
  },
  "sccache": true,
  "extra_bootstrap": [
    "rustup component add rustfmt clippy",
    "git config --global http.sslVerify false",
    "cargo install --git https://github.com/yannickgranger/cfdb.git --rev 02c5a45 --root /usr/local --locked --quiet cfdb-cli || true",
    "cargo install --git https://github.com/yannickgranger/graph-specs.git --rev ecaedb9 --root /usr/local --locked --quiet application || true"
  ]
}
