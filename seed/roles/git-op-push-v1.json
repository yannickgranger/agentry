{
  "name": "git-op-push",
  "version": 1,
  "model": null,
  "system_prompt": null,
  "image": "docker.io/library/debian:trixie-slim",
  "substrate_class": "podman",
  "package_manager": "apt",
  "entrypoint_script": "#!/bin/sh\nexec /usr/local/bin/git-op-push\n",
  "binaries": ["git", "ca-certificates"],
  "mcp_servers": [],
  "tool_allowlist": ["git"],
  "permit_scope": [
    "fs:read:/workspace/**",
    "fs:write:/workspace/**",
    "${FORGE_NET_ALLOW}",
    "${FORGE_WRITE_PERMITS}"
  ],
  "passthru_env": ["GITEA_TOKEN"],
  "mounts": [
    {
      "source": "~/.local/bin/git-op-push",
      "target": "/usr/local/bin/git-op-push",
      "readonly": true
    }
  ],
  "workspace_mount": {
    "container_path": "/workspace",
    "readonly": false
  },
  "sccache": false
}
