{
  "name": "shipper-agentry",
  "version": 1,
  "model": null,
  "system_prompt": null,
  "image": "docker.io/library/debian:trixie-slim",
  "substrate_class": "podman",
  "package_manager": "apt",
  "entrypoint_script": "#!/bin/sh\nexec /usr/local/bin/shipper-runner\n",
  "binaries": ["git", "curl", "ca-certificates"],
  "mcp_servers": [],
  "tool_allowlist": [],
  "permit_scope": [
    "${FORGE_NET_ALLOW}",
    "${FORGE_WRITE_PERMITS}"
  ],
  "passthru_env": ["GITEA_TOKEN"],
  "mounts": [
    {
      "source": "${HOME}/.local/bin/shipper-runner",
      "target": "/usr/local/bin/shipper-runner",
      "readonly": true
    }
  ],
  "workspace_mount": {
    "container_path": "/workspace",
    "readonly": false
  },
  "sccache": false
}
