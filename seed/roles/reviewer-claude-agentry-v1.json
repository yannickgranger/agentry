{
  "name": "reviewer-claude-agentry",
  "version": 1,
  "model": "claude-max",
  "system_prompt": null,
  "image": "docker.io/library/debian:trixie-slim",
  "substrate_class": "podman",
  "package_manager": "apt",
  "entrypoint_script": "#!/bin/sh\nexec /usr/local/bin/reviewer-claude-runner\n",
  "binaries": ["git", "ca-certificates"],
  "mcp_servers": [],
  "tool_allowlist": [],
  "permit_scope": [
    "fs:read:/workspace/**",
    "net:allow:api.anthropic.com",
    "net:allow:agency.lab"
  ],
  "passthru_env": [],
  "mounts": [
    {
      "source": "${HOME}/.local/bin/claude",
      "target": "/usr/local/bin/claude",
      "readonly": true
    },
    {
      "source": "${HOME}/.claude/.credentials.json",
      "target": "/root/.claude/.credentials.json",
      "readonly": true
    },
    {
      "source": "${HOME}/.config/agentry/claude-container-settings.json",
      "target": "/root/.claude/settings.json",
      "readonly": true
    },
    {
      "source": "/var/lib/agentry/transcripts",
      "target": "/transcripts",
      "readonly": false
    },
    {
      "source": "${HOME}/.local/bin/ra-query",
      "target": "/usr/local/bin/ra-query",
      "readonly": true
    },
    {
      "source": "${HOME}/.local/bin/reviewer-claude-runner",
      "target": "/usr/local/bin/reviewer-claude-runner",
      "readonly": true
    }
  ],
  "workspace_mount": {
    "container_path": "/workspace",
    "readonly": true
  },
  "sccache": false,
  "extra_bootstrap": [
    "ra-query crate-health . || true"
  ]
}
