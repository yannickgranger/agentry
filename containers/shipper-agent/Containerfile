# shipper-agent — clones a forge repo, writes a file, opens a PR.
# Used by M7 E2E. Requires `GITEA_TOKEN` via role.passthru_env.

FROM alpine:3.21

RUN apk add --no-cache bash coreutils git curl jq ca-certificates

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
