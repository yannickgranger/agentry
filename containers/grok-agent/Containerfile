# grok-agent — cheap xAI Grok agent (M5a).
#
# Reads a startup bundle on stdin, extracts brief.payload.prompt, calls
# api.x.ai/v1/chat/completions with $XAI_API_KEY, emits the response as
# an event, then `done shipped`. No Anthropic API. Ever.

FROM alpine:3.21
RUN apk add --no-cache bash coreutils curl jq
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
