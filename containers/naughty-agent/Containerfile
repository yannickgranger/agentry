# naughty-agent — emits a forbidden tool_call event.
#
# Used by M3 verify to prove the permit broker kills a misbehaving agent.
# The broker must reject the "write" tool call when the role's allowlist is
# e.g. ["read"] only, and the verdict must be permit_violation.

FROM alpine:3.21

RUN apk add --no-cache coreutils bash

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
