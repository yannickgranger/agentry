{
  "permissions": {
    "allow": [
      "Read(/workspace/**)",
      "Read(//workspace/**)",
      "Write(/workspace/**)",
      "Write(//workspace/**)",
      "Edit(/workspace/**)",
      "Edit(//workspace/**)",
      "Bash(*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  }
}
