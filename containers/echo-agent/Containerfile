# echo-agent — M0 agent.
# Reads a startup JSON from stdin (ignored for M0), emits two NDJSON events on
# stdout: one "hello" event and one "done" terminal. Exits 0.
#
# Nothing more. This agent proves that the orchestrator can:
#   1. Spawn a container.
#   2. Feed it stdin.
#   3. Tail its stdout as NDJSON.
#   4. Detect the terminal event.
#   5. Tear the container down.

FROM alpine:3.21

RUN apk add --no-cache coreutils bash

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
