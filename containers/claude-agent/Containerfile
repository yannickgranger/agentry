# claude-agent — Claude Max via host `claude` CLI (M5b).
#
# Bind-mount targets (declared by role.mounts at spawn):
#   - /usr/local/bin/claude              : host `claude` binary
#   - /root/.claude/.credentials.json    : host OAuth credentials
#   - /root/.claude/settings.json        : host settings (optional)
#
# The container only contains the bash+jq harness; the binary lives on the
# host and is re-used per spawn. Zero Anthropic API. Zero per-token spend.

FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends bash coreutils ca-certificates jq \
    && rm -rf /var/lib/apt/lists/*

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
# Create the bind-mount target directory so podman can mount into it.
RUN mkdir -p /root/.claude

ENTRYPOINT ["/entrypoint.sh"]
